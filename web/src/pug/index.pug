doctype html
html
  include @/@loadingio/bootstrap.ext/index.pug
  head
    +css([
      {name: "bootstrap", path: "dist/css/bootstrap.min.css"},
      {name: "@loadingio/bootstrap.ext"}
    ])
  body: .p-4
    .text-center
      .btn.btn-outline-dark.btn-upload.mb-4
        span Upload
        input.form-control(ld="file",type="file")
      .card: .card-body: div(ld="output")
    +script([
      {name: "ldview"},
      {name: "imgtype", version: "dev"}
    ])
    script(type="module"): include:lsc index.ls
